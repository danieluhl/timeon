<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.duhd.timeon</string>
	<key>ProgramArguments</key>
	<array>
		<string>/usr/local/bin/timeon</string>
		<string>daemon</string>
	</array>
	<key>RunAtLoad</key>
	<true/>
	<key>KeepAlive</key>
	<true/>
	<key>LimitLoadToSessionType</key>
	<array>
		<string>Aqua</string>
	</array>
	<key>StandardOutPath</key>
	<string>HOME_PLACEHOLDER/git/timeon/reports/timeon.log</string>
	<key>StandardErrorPath</key>
	<string>HOME_PLACEHOLDER/git/timeon/reports/timeon.err</string>
	<key>EnvironmentVariables</key>
	<dict>
		<key>HOME</key>
		<string>HOME_PLACEHOLDER</string>
	</dict>
</dict>
</plist>
